{
  "description": "agent-starter quality hooks: format-on-save, auto-test on edit, and once-per-turn typecheck/lint on stop.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/format-on-save.sh",
            "timeout": 30,
            "statusMessage": "Formatting..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/auto-test.sh",
            "timeout": 120,
            "statusMessage": "Running matching tests..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/typecheck-on-stop.sh",
            "timeout": 10,
            "statusMessage": "Marking session dirty for type-check..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/lint-on-stop.sh",
            "timeout": 10,
            "statusMessage": "Marking session dirty for lint..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/typecheck-on-stop.sh",
            "timeout": 120,
            "statusMessage": "Type-checking changed code..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/lint-on-stop.sh",
            "timeout": 120,
            "statusMessage": "Linting changed code..."
          }
        ]
      }
    ]
  }
}
